{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "Template",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "https://github.com/errormikey/no-a-repo",
        "sources": "https://github.com/errormikey/no-a-repo"
    },
    "license": "MPL-2",
    "icon": "assets/modid/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "dev.nanite.library.fabric.NaniteLibraryFabric"
        ],
        "client": [
            "dev.nanite.library.fabric.client.NaniteLibraryClientFabric"
        ],
        "fabric-datagen": [
            "dev.nanite.library.fabric.datagen.NaniteLibraryDataGen"
        ]
    },
    "mixins": [
        "nanitelibrary.mixins.json",
        "nanitelibrary.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.14",
        "fabric-api": "*",
        "minecraft": ">=1.20",
        "java": ">=17"
    }
}
