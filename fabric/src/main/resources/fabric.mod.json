{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "Template",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "https://github.com/nanite/nanite-library",
        "sources": "https://github.com/nanite/nanite-library"
    },
    "license": "MPL-2",
    "environment": "*",
    "entrypoints": {
        "main": [
            "dev.nanite.library.fabric.NaniteLibraryFabric"
        ],
        "client": [
            "dev.nanite.library.fabric.client.NaniteLibraryClientFabric"
        ],
        "fabric-datagen": [
            "dev.nanite.library.fabric.datagen.NaniteLibraryDataGen"
        ]
    },
    "mixins": [
        "nanitelibrary.mixins.json",
        "nanitelibrary.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.18",
        "fabric-api": "${fabric_api_version_range}",
        "minecraft": "${minecraft_version_range_sem}",
        "java": ">=25"
    }
}
